                        <div><label class="form-label">Tháng vận hành</label><select id="month" class="form-input font-semibold"><option value="1">Tháng 1</option><option value="2">Tháng 2</option><option value="3">Tháng 3</option><option value="4">Tháng 4</option><option value="5">Tháng 5</option><option value="6">Tháng 6</option><option value="7">Tháng 7</option><option value="8">Tháng 8</option><option value="9">Tháng 9</option><option value="10">Tháng 10</option><option value="11">Tháng 11</option><option value="12">Tháng 12</option></select></div>
                        <div><label class="form-label">Trạng thái</label><select id="status" onchange="toggleReason()" class="form-input font-bold"><option value="Hoàn thành">Hoàn thành</option><option value="Đang diễn ra">Đang diễn ra</option><option value="Hủy">Hủy</option><option value="Dời lịch">Dời lịch</option><option value="Khác">Khác</option></select></div>
                    </div>
                    
                    <div id="reasonBox" class="hidden"><label class="form-label">Lý do cụ thể</label><input type="text" id="reason" placeholder="Nhập lý do dời/hủy..." class="form-input italic bg-slate-50"></div>

                    <div class="grid grid-cols-2 gap-6">
                        <div><label class="form-label">Ngày bắt đầu (Lọc HRM)</label><input type="date" id="start" class="form-input"></div>
                        <div><label class="form-label">Ngày kết thúc (Test L2)</label><input type="date" id="finish" class="form-input"></div>
                    </div>

                    <div class="space-y-4">
                        <label class="form-label">Lưu trữ Links dữ liệu</label>
                        <input type="url" id="listLink" placeholder="Link danh sách thi (Google Sheet)" class="form-input">
                        <input type="url" id="quizLink" placeholder="Link kết quả Test Lần 1 & 2 (Google Sheet)" class="form-input">
                    </div>

                    <button onclick="submitFinal()" class="w-full bg-blue-600 text-white font-bold py-5 rounded-3xl shadow-xl hover:bg-blue-700 transition transform hover:scale-[1.01] uppercase tracking-wider text-sm shadow-blue-100">Gửi dữ liệu về Dashboard Trainer Hub</button>
                </div>
            </div>
        </div>

    </main>

    <!-- SUCCESS MODAL -->
    <div id="successModal" class="hidden fixed inset-0 z-[100] modal-overlay flex items-center justify-center p-6">
        <div class="bg-white rounded-[32px] p-12 max-w-sm w-full text-center shadow-2xl">
            <div class="w-20 h-20 bg-green-100 text-green-600 rounded-full flex items-center justify-center mx-auto mb-6 shadow-inner"><i data-lucide="check-circle-2" class="w-10 h-10"></i></div>
            <h3 class="text-2xl font-bold text-slate-900 mb-2">Đã Submit!</h3>
            <p class="text-sm text-slate-400 font-medium mb-10 leading-relaxed">Dữ liệu khóa học đã được cập nhật vào báo cáo Master Hub.</p>
            <div class="flex flex-col gap-3">
                <a href="trainer.html" class="bg-blue-600 text-white font-bold py-4 rounded-2xl shadow-lg shadow-blue-100 hover:bg-blue-700 transition">Về Dashboard Báo cáo</a>
                <button onclick="location.reload()" class="text-slate-400 font-bold text-xs uppercase tracking-widest hover:text-slate-600 transition">Tiếp tục ở lại</button>
            </div>
        </div>
    </div>

    <script>
        lucide.createIcons();

        function showStep(id) {
            document.querySelectorAll('.step-content').forEach(s => s.classList.remove('active'));
            document.getElementById(id).classList.add('active');
            document.querySelectorAll('.sidebar-item').forEach(i => i.classList.remove('active'));
            document.getElementById('btn-' + id).classList.add('active');
            window.scrollTo(0,0);
        }

        function toggleReason() {
            const s = document.getElementById('status').value;
            document.getElementById('reasonBox').classList.toggle('hidden', !['Hủy','Dời lịch','Khác'].includes(s));
        }

        function copy(id) {
            const t = document.getElementById(id).innerText;
            navigator.clipboard.writeText(t).then(() => alert('Copied Content!'));
        }

        // Checklist Logic (Cập nhật cho Mã Ngành Hàng: RETAIL)
        function checkTask(i) {
            let data = JSON.parse(localStorage.getItem('trainer_checklists')) || { RETAIL: { completed: false, steps: {} } };
            if(!data.RETAIL) data.RETAIL = { completed: false, steps: {} }; // Đảm bảo object tồn tại nếu localstorage đã có khóa khác
            
            data.RETAIL.steps[i] = !data.RETAIL.steps[i];
            const allChecked = Object.values(data.RETAIL.steps).filter(v => v).length >= 4; 
            data.RETAIL.completed = allChecked;
            localStorage.setItem('trainer_checklists', JSON.stringify(data));
        }

        // SUBMIT TO TRAINER HUB (Cập nhật category)
        function submitFinal() {
            const newEntry = {
                category: 'RETAIL',
                groupName: 'Sản phẩm KV1 RETAIL',
                courseId: document.getElementById('courseId').value,
                month: document.getElementById('month').value,
                status: document.getElementById('status').value,
                reason: document.getElementById('reason').value,
                startDate: document.getElementById('start').value,
                finishDate: document.getElementById('finish').value,
                listLink: document.getElementById('listLink').value || '#',
                quizLink: document.getElementById('quizLink').value || '#',
                recordLink: '#' // Retail này dường như không dạy qua Zoom, chỉ làm test LMS
            };

            if(!newEntry.courseId || !newEntry.finishDate) return alert('Vui lòng nhập Mã khóa (Tháng) và Ngày kết thúc!');

            let db = JSON.parse(localStorage.getItem('kv_master_db')) || [];
            db.push(newEntry);
            localStorage.setItem('kv_master_db', JSON.stringify(db));
            
            document.getElementById('successModal').classList.remove('hidden');
        }
    </script>
</body>
</html>
